---
import Base from '../layouts/Base.astro'
import FlowDiagram from '../components/FlowDiagram.astro'

const base = import.meta.env.BASE_URL

const features = [
  { icon: '🔍', title: 'Application discovery', body: 'Søk etter Nais-team og velg hvilke applikasjoner som skal overvåkes.' },
  { icon: '📦', title: 'Deployment tracking', body: 'Nye deployments fra Nais fanges opp og synkroniseres automatisk.' },
  { icon: '✅', title: 'Fire-øyne-verifisering', body: 'Sjekker automatisk at hver endring har en godkjent pull request.' },
  { icon: '🚨', title: 'Repository-varsler', body: 'Varsler dersom et deployment kommer fra et uventet repository.' },
  { icon: '🧩', title: 'Ureviewede commits', body: 'Oppdager kode som er smuglet inn sammen med godkjente PR-er.' },
  { icon: '💬', title: 'Slack-integrasjon', body: 'Få deployment-varsler i kanal, med mulighet til å lenke til Slack ved behov.' },
  { icon: '🎯', title: 'Endringsopphav', body: 'Knytt leveranser til mål og nøkkelresultater (OKR) i en målplakat, automatisk fra commit eller branch.' },
  { icon: '📈', title: 'Statistikk & rapporter', body: 'Audit-rapporter (PDF/Excel) med både fire-øyne-dekning og endringsopphav for valgt periode.' },
]
---

<Base>
  <!-- HERO -->
  <section class="hero">
    <div class="container hero__inner">
      <img class="hero__logo" src={`${base}nda-logo.svg`} alt="" width="72" height="72" />
      <p class="hero__kicker">NDA · Deployment Audit</p>
      <h1>Gjør det lett å gjøre rett</h1>
      <p class="hero__lead">
        NDA gir deg og teamet automatisk oversikt over at deployments på Nais følger
        fire-øyne-prinsippet. I tillegg kobles hver leveranse til målet den hører til.
        God praksis blir synlig og dokumentert, uten ekstra arbeid.
      </p>
      <div class="hero__cta">
        <a class="btn btn--primary" href="https://nda.ansatt.nav.no" target="_blank" rel="noopener noreferrer">Åpne appen ↗</a>
        <a class="btn btn--ghost" href="https://github.com/navikt/nda" target="_blank" rel="noopener noreferrer">Se kildekoden ↗</a>
      </div>
      <p class="hero__note">Appen er tilgjengelig for alle med Nav-maskin. Denne siden og kildekoden er åpne for alle.</p>
    </div>
  </section>

  <!-- HVORFOR NDA -->
  <section class="section" id="hvorfor">
    <div class="container">
      <p class="eyebrow">Hvorfor NDA</p>
      <h2>God praksis, gjort enkel og synlig</h2>
      <p class="section__lead">
        Enten dere jobber i pull requests eller godkjenner i etterkant, gjør NDA det synlig og
        dokumenterbart automatisk. Oversikten er der allerede, så det å <em>vise</em> at
        deployments følger fire-øyne blir like lett som å gjøre det.
      </p>

      <div class="grid grid--3" style="margin-top:2rem">
        <div class="card">
          <span class="card__icon" aria-hidden="true">⚡</span>
          <h3>Oversikt på sekunder</h3>
          <p>Se fire-øyne-status for alle appene dine ett sted, uten å lete deg gjennom GitHub.</p>
        </div>
        <div class="card">
          <span class="card__icon" aria-hidden="true">📄</span>
          <h3>Dokumentasjon som lager seg selv</h3>
          <p>Godkjenningshistorikken samles løpende og er klar den dagen noen spør etter den.</p>
        </div>
        <div class="card">
          <span class="card__icon" aria-hidden="true">🛟</span>
          <h3>En trygghet i ryggen</h3>
          <p>De sjeldne avvikene dukker opp tidlig, så teamet kan rette dem i ro og mak.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- TO VEIER / ARBEIDSFLYT -->
  <section class="section paths" id="arbeidsflyt">
    <div class="container">
      <p class="eyebrow">Tilpasset arbeidsflyten deres</p>
      <h2>To veier til samme mål</h2>
      <p class="section__lead">
        NDA krever ikke at dere legger om måten dere jobber på. Bruker dere pull requests, går
        verifiseringen av seg selv. Gjør dere det ikke, godkjenner dere like gjerne i etterkant,
        rett i NDA. Begge veier ender med dokumentert fire-øyne.
      </p>
      <div class="grid grid--2" style="margin-top:2rem">
        <div class="card path-card">
          <span class="card__icon" aria-hidden="true">🔀</span>
          <h3>Proaktivt med pull requests</h3>
          <p>
            Jobber teamet med PR-er? NDA henter godkjenninger, reviewers og CI-status fra GitHub
            automatisk. Dere trenger ikke gjøre noe ekstra. Det bare stemmer.
          </p>
        </div>
        <div class="card path-card">
          <span class="card__icon" aria-hidden="true">✅</span>
          <h3>Retroaktivt i NDA</h3>
          <p>
            Jobber dere ikke PR-basert, eller pushet rett til main? Godkjenn deploymentet i
            etterkant rett i NDA. Vil dere, kan dere legge ved en kommentar eller lenke som
            utdyper, men det er ikke et krav.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- SLIK FUNKER DET -->
  <section class="section" id="slik-funker-det">
    <div class="container">
      <p class="eyebrow">Slik funker det</p>
      <h2>Fra Nais-deployment til verifisert godkjenning</h2>
      <p class="section__lead">
        NDA kobler sammen Nais og GitHub. Den henter deployments, verifiserer dem mot
        pull request-historikken, og flagger alt som ikke stemmer. Det skjer helt automatisk.
      </p>
      <div style="margin-top:2.5rem">
        <FlowDiagram />
      </div>
      <p class="section__lead" style="margin-top:2.5rem">
        Hele verifiseringslogikken er dokumentert i
        <a href="https://github.com/navikt/nda/blob/main/docs/verification.md" target="_blank" rel="noopener noreferrer">verification.md</a>,
        med flytdiagram og kodereferanser for full sporbarhet. Der finner du blant annet implisitt
        godkjenning, base-branch-merge og deteksjon av ureviewede commits.
      </p>
    </div>
  </section>

  <!-- ENDRINGSOPPHAV -->
  <section class="section section--subtle" id="endringsopphav">
    <div class="container audience">
      <div>
        <p class="eyebrow">Endringsopphav</p>
        <h2>Hver leveranse koblet til målet sitt</h2>
        <p class="section__lead">
          Ved siden av fire-øyne samler NDA også inn <strong>endringsopphav</strong>, altså hvorfor
          en endring ble levert. Nøkkelord i commit-melding eller branch-navn knytter leveransen
          automatisk til riktig mål eller nøkkelresultat i en målplakat. Ingen manuell registrering.
        </p>
        <p class="section__lead">
          Slik dekker dere behovet for endringsopphav uten ekstra arbeid, enten dere styrer etter
          OKR (mål og nøkkelresultater) eller jobber tight-loose-tight.
        </p>
      </div>
      <ul class="checklist">
        <li><strong>Fra mål til leveranser:</strong> se alle leveranser knyttet til et mål eller nøkkelresultat i målplakaten.</li>
        <li><strong>Fra leveranse til mål:</strong> se hvilke(t) mål eller nøkkelresultat en enkelt leveranse hører til.</li>
        <li><strong>Automatisk kobling</strong> via nøkkelord i commit-melding eller branch-navn.</li>
        <li><strong>Med i rapporten:</strong> endringsopphav rapporteres sammen med fire-øyne-dekning for valgt periode.</li>
      </ul>
    </div>
  </section>

  <!-- FUNKSJONER -->
  <section class="section" id="funksjoner">
    <div class="container">
      <p class="eyebrow">Funksjoner</p>
      <h2>Hva du får</h2>
      <div class="grid grid--3 grid--4" style="margin-top:2rem">
        {
          features.map((f) => (
            <div class="card">
              <span class="card__icon" aria-hidden="true">{f.icon}</span>
              <h3>{f.title}</h3>
              <p>{f.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- FOR REVISORER -->
  <section class="section section--subtle" id="revisor">
    <div class="container audience">
      <div>
        <p class="eyebrow">For revisorer og seksjonsledere</p>
        <h2>Dokumentasjon som er klar når revisjonen er det</h2>
        <p class="section__lead">
          NDA gir et etterprøvbart bilde av fire-øyne-dekning over tid, per applikasjon, miljø og
          periode. Tallene er knyttet til konkrete deployments og pull requests, så de alltid kan
          spores tilbake til kilden.
        </p>
      </div>
      <ul class="checklist">
        <li><strong>Fire-øyne-dekning</strong> i prosent, med opptelling av godkjente, ikke-godkjente og ventende deployments.</li>
        <li><strong>Endringsopphav</strong> viser hvor stor andel av leveransene som er koblet til et mål eller nøkkelresultat.</li>
        <li><strong>Skriver aldri til GitHub.</strong> Appen har kun lesetilgang og kan ikke endre kode eller godkjenninger.</li>
        <li><strong>Audit-rapporter</strong> kan genereres og lastes ned som PDF og Excel for en valgt periode.</li>
        <li><strong>Maskin-til-maskin-API</strong> (Entra ID-sikret) leverer fire-øyne-data til andre systemer, f.eks. KISS.</li>
        <li><strong>Strukturert logging</strong> med trace-id og pgaudit gir full sporbarhet i ELK og Loki.</li>
      </ul>
    </div>
  </section>

  <!-- FOR UTVIKLERE -->
  <section class="section" id="utvikler">
    <div class="container audience">
      <div>
        <p class="eyebrow">For utviklere og tech-leads</p>
        <h2>Åpen kildekode, kjent stack</h2>
        <p class="section__lead">
          NDA er bygget på en moderne, gjenkjennelig Nav-stack og kjører på Nais. Alt er åpent.
          Les koden, kjør den lokalt, eller bidra.
        </p>
        <div class="stack">
          <span>React Router 8 (SSR)</span>
          <span>TypeScript</span>
          <span>PostgreSQL</span>
          <span>Aksel v8</span>
          <span>Nais GraphQL</span>
          <span>GitHub REST</span>
          <span>Express 5</span>
          <span>Slack Bolt</span>
        </div>
        <div class="hero__cta" style="margin-top:1.5rem">
          <a class="btn btn--primary" href="https://github.com/navikt/nda" target="_blank" rel="noopener noreferrer">Til repoet ↗</a>
          <a class="btn btn--secondary" href={`${base}storybook/`}>Se Storybook</a>
        </div>
      </div>
      <div class="card code-card">
        <p class="code-card__title">Kom i gang lokalt</p>
        <pre><code>git clone https://github.com/navikt/nda
cd nda
pnpm install
cp .env.example .env   # fyll inn GitHub App + Nais
pnpm run db:migrate
pnpm run dev           # http://localhost:5173</code></pre>
        <p class="code-card__note">
          Krever lesetilgang via en GitHub App (Contents, Metadata, Pull requests, Checks) og
          tilgang til Nais-APIet. Se <a href="https://github.com/navikt/nda#readme" target="_blank" rel="noopener noreferrer">README</a> for full oppsettsguide.
        </p>
      </div>
    </div>
  </section>

  <!-- CTA-BÅND -->
  <section class="cta-band">
    <div class="container cta-band__inner">
      <div>
        <h2>Vil du se oversikten for teamet ditt?</h2>
        <p>Åpne appen og legg til appene dine, eller utforsk koden på GitHub.</p>
      </div>
      <div class="hero__cta">
        <a class="btn btn--secondary" href="https://nda.ansatt.nav.no" target="_blank" rel="noopener noreferrer">Åpne appen ↗</a>
        <a class="btn btn--ghost" href="https://github.com/navikt/nda" target="_blank" rel="noopener noreferrer">GitHub ↗</a>
      </div>
    </div>
  </section>

  <style>
    /* HERO */
    .hero {
      background:
        radial-gradient(1200px 500px at 80% -10%, rgba(102, 204, 102, 0.18), transparent 60%),
        linear-gradient(160deg, var(--blue-900), var(--blue-800));
      color: #fff;
    }
    .hero__inner {
      padding-block: clamp(3.5rem, 2.5rem + 6vw, 7rem);
      max-width: 60ch;
    }
    .hero__logo {
      filter: drop-shadow(0 6px 16px rgba(0, 0, 0, 0.35));
      margin-bottom: 1.2rem;
    }
    .hero__kicker {
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      font-size: 0.82rem;
      color: var(--green-300);
      margin: 0 0 0.6rem;
    }
    .hero h1 {
      color: #fff;
    }
    .hero__lead {
      font-size: 1.2rem;
      color: #cfe0ee;
      margin-top: 0.5rem;
    }
    .hero__cta {
      display: flex;
      flex-wrap: wrap;
      gap: 0.8rem;
      margin-top: 1.8rem;
    }
    .hero__note {
      margin-top: 1.2rem;
      font-size: 0.88rem;
      color: #9fbdd6;
    }

    /* Funksjons-grid: utvid til 4 kolonner på store skjermer */
    @media (min-width: 1040px) {
      .grid--4 {
        grid-template-columns: repeat(4, 1fr);
      }
    }

    /* Målgruppe-seksjoner: to kolonner */
    .audience {
      display: grid;
      gap: 2.5rem;
      align-items: start;
    }
    @media (min-width: 900px) {
      .audience {
        grid-template-columns: 1fr 1fr;
        gap: 3.5rem;
      }
    }

    .stack {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-top: 1.4rem;
    }
    .stack span {
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--blue-800);
      background: var(--blue-100);
      border: 1px solid var(--blue-300);
      padding: 0.3rem 0.7rem;
      border-radius: 999px;
    }

    .code-card {
      background: var(--blue-900);
      border: none;
    }
    .code-card__title {
      color: var(--green-300);
      font-weight: 700;
      font-size: 0.85rem;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      margin: 0 0 0.8rem;
    }
    .code-card pre {
      margin: 0;
      overflow-x: auto;
      background: rgba(0, 0, 0, 0.25);
      border-radius: 10px;
      padding: 1rem;
    }
    .code-card code {
      background: none;
      color: #e7f0f8;
      font-size: 0.86rem;
      line-height: 1.7;
      white-space: pre;
    }
    .code-card__note {
      color: #a9c2d6;
      font-size: 0.88rem;
      margin: 1rem 0 0;
    }
    .code-card__note a {
      color: var(--green-300);
    }

    /* To veier / arbeidsflyt */
    .paths {
      background: var(--blue-100);
      border-block: 1px solid var(--blue-300);
    }
    .path-card {
      border-color: var(--blue-300);
    }
    .path-card .card__icon {
      font-size: 2rem;
    }

    /* CTA-bånd */
    .cta-band {
      background: var(--blue-500);
      color: #fff;
      padding-block: 3rem;
    }
    .cta-band__inner {
      display: flex;
      flex-wrap: wrap;
      gap: 1.5rem 2.5rem;
      align-items: center;
      justify-content: space-between;
    }
    .cta-band h2 {
      color: #fff;
      margin: 0;
    }
    .cta-band p {
      margin: 0.4rem 0 0;
      color: #dcebf8;
    }
  </style>
</Base>
