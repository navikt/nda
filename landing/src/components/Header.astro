---
const base = import.meta.env.BASE_URL
const nav = [
  { href: '#hvorfor', label: 'Hvorfor NDA' },
  { href: '#slik-funker-det', label: 'Fire-øyne' },
  { href: '#endringsopphav', label: 'Endringsopphav' },
  { href: '#revisor', label: 'For revisorer' },
  { href: '#utvikler', label: 'For utviklere' },
]
---

<header class="site-header">
  <div class="container site-header__inner">
    <a class="brand" href={base} aria-label="NDA – Deployment Audit, til toppen">
      <img src={`${base}nda-logo.svg`} alt="" width="36" height="36" />
      <span class="brand__text">
        <strong>NDA</strong>
        <span class="brand__sub">Deployment Audit</span>
      </span>
    </a>

    <nav class="site-nav" aria-label="Seksjoner">
      {nav.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>

    <a class="site-header__gh" href="https://github.com/navikt/nda" target="_blank" rel="noopener noreferrer">
      GitHub ↗
    </a>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--border);
  }
  .site-header__inner {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    min-height: 64px;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    color: var(--blue-900);
  }
  .brand__text {
    display: flex;
    flex-direction: column;
    line-height: 1.05;
  }
  .brand__text strong {
    font-size: 1.05rem;
    letter-spacing: 0.02em;
  }
  .brand__sub {
    font-size: 0.78rem;
    color: var(--ink-muted);
  }
  .site-nav {
    display: none;
    gap: 1.4rem;
    margin-left: auto;
  }
  .site-nav a {
    text-decoration: none;
    color: var(--ink);
    font-weight: 600;
    font-size: 0.95rem;
    padding: 0.25rem 0;
    border-bottom: 2px solid transparent;
  }
  .site-nav a:hover {
    border-bottom-color: var(--blue-500);
    color: var(--blue-700);
  }
  .site-header__gh {
    margin-left: auto;
    text-decoration: none;
    font-weight: 600;
    color: var(--blue-700);
    white-space: nowrap;
  }
  @media (min-width: 880px) {
    .site-nav {
      display: flex;
    }
    .site-header__gh {
      margin-left: 0;
    }
  }
</style>
