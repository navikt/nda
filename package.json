{
  "name": "deployment-audit",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "pnpm": {
    "overrides": {
      "@tootallnate/once@<3.0.1": ">=3.0.1",
      "axios@<1.16.0": ">=1.16.0 <2.0.0",
      "lodash@<=4.17.23": ">=4.18.0",
      "lodash@>=4.0.0 <=4.17.23": ">=4.18.0",
      "vite@>=7.0.0 <=7.3.1": ">=7.3.2 <8.0.0",
      "vite@>=7.1.0 <=7.3.1": ">=7.3.2 <8.0.0",
      "@types/node": "^24.13.2"
    }
  },
  "engines": {
    "node": "^24.0.0",
    "npm": "^11.0.0"
  },
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "start": "tsx scripts/migrate.ts && react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "check": "pnpm run lint && pnpm run typecheck",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:all": "vitest run && vitest run --config vitest.integration.config.ts",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "db:migrate": "node-pg-migrate up -m app/db/migrations",
    "db:migrate:down": "node-pg-migrate down -m app/db/migrations",
    "db:migrate:create": "node-pg-migrate create -m app/db/migrations",
    "db:init": "tsx scripts/init-db.ts",
    "test:nais-discovery": "tsx scripts/test-nais.ts discovery",
    "test:nais-fetch": "tsx scripts/test-nais.ts fetch",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "knip": "knip",
    "format": "biome format --write .",
    "prepare": "lefthook install",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@fontsource/source-sans-pro": "^5.2.5",
    "@google-cloud/storage": "^7.21.0",
    "@navikt/aksel-icons": "^8.13.0",
    "@navikt/ds-css": "^8.13.0",
    "@navikt/ds-react": "^8.13.0",
    "@octokit/auth-app": "^8.2.0",
    "@octokit/rest": "^22.0.1",
    "@opentelemetry/api": "^1.9.1",
    "exceljs": "npm:@protobi/exceljs@4.4.0-protobi.10",
    "@react-pdf/renderer": "^4.5.1",
    "@react-router/express": "^7.18.0",
    "@react-router/node": "7.18.0",
    "@react-router/serve": "7.18.0",
    "@slack/bolt": "^4.7.3",
    "@slack/types": "^2.21.1",
    "@types/pg": "^8.18.0",
    "chart.js": "^4.5.1",
    "compression": "^1.8.1",
    "dotenv": "^17.4.2",
    "express": "^4.22.1",
    "graphql": "^16.14.2",
    "graphql-request": "^7.4.0",
    "helmet": "^8.2.0",
    "isbot": "^5.1.43",
    "jose": "^6.2.3",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.21.0",
    "react": "^19.2.7",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.7",
    "react-router": "7.18.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@react-router/dev": "7.18.0",
    "@storybook/react": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@testcontainers/postgresql": "^12.0.3",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "@types/express-serve-static-core": "^5.1.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.1.0",
    "knip": "^6.16.1",
    "lefthook": "^2.1.9",
    "storybook": "^10.4.6",
    "testcontainers": "^12.0.2",
    "tsx": "^4.22.4",
    "typescript": "^5.9.2",
    "vite": "^7.1.7",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  }
}
